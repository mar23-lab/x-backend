{
  "schema_version": "xcp.shared_access_contract_pack.v1",
  "pack_version": "2026.05.21",
  "authority": "xcp-platform",
  "governance_authority": "MB-P",
  "product_consumers": [
    "xlooop",
    "xcp-control-plane"
  ],
  "package_manager_policy": "vendor_public_safe_pack_for_cloud_deploys_no_sibling_file_dependencies",
  "source_authority_policy": {
    "current_source_authority": {
      "xcp-platform": "GitHub mar23-lab/xcp-platform plus governed local clone",
      "Xlooop-XCP-demo": "GitHub mar23-lab/Xlooop-XCP-demo plus governed local clone",
      "x-biz": "GitHub mar23-lab/x-biz plus governed local clone",
      "x-docs": "GitHub x-ude/x-docs read-only evidence unless owner-approved",
      "x-front": "GitHub x-ude/x-front read-only evidence unless owner-approved"
    },
    "legacy_provenance": {
      "Bitbucket": "historical/provenance only; never an active dependency or default context"
    },
    "local_clone_authority": "local clones are execution evidence only when MB-P route and branch guards authorize the target",
    "owner_boundary": "Ilmir-owned x-front and x-docs are read-only from Marat-owned sessions until explicit owner-approved scope exists",
    "governance_source": "MB-P CANONICAL_SOURCES_REGISTRY.yml"
  },
  "canonical_access_chain": [
    "cloudflare_access_identity",
    "app_entitlement",
    "tenant_membership",
    "role_permission",
    "operating_context",
    "receipt_policy"
  ],
  "required_packages": [
