    "ActorRef",
    "ActivityEventProjection",
    "WorkItemAssignmentProjection",
    "NotificationSourceProjection",
    "FixtureProvenance",
    "DisplaySurfaceTaxonomy"
  ],
  "forbidden_consumer_patterns": [
    "sibling file dependency to xcp-platform",
    "xlooop entitlement implies xcp entitlement",
    "operator mode without backend entitlement check",
    "feedback mode as separate authority",
    "Bitbucket as active source authority",
    "product repo inferred from local path instead of MB-P route authority",
    "role route rendered as workspace member",
    "agent capability rendered as invited staff",
    "role route or capability rendered as task owner",
    "ambiguous who field for non-human activity source",
    "storybook member fixture with kind agent while agent_profile is deferred",
    "automation capability grouped under role routes as if it were an invocation persona",
    "agent_profile treated as live before deferred trigger conditions are met"
  ],
