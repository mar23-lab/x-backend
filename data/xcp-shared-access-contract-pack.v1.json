      "xcp_platform_admin",
      "company_telemetry_viewer"
    ],
    "telemetry_scopes": [
      "company_aggregate_usage",
      "tenant_admin_summary",
      "tenant_raw_break_glass",
      "mbp_internal_governance"
    ],
    "xcp_default_entitlement": "disabled",
    "xlooop_access_grants_xcp": false,
    "test_mode_behavior": "feedback_annotation_only_non_mutating",
    "access_code_security_role": "invitation_routing_hint_not_authentication",
    "tenant_raw_scope_policy": "audited_break_glass_required_not_default_owner_view",
    "paid_pilot_contracts": [
      "PaidPilotAuthorityContract",
      "PaidPilotAuthorityEvidence",
      "PaidPilotPrincipalKind",
      "ActorRef",
      "WorkspaceMemberProjection",
      "ProjectMemberProjection",
      "GovernedRoleRouteProjection",
      "AgentCapabilityProjection",
      "AgentRuntimeEvent",
      "ActivityEventProjection",
      "WorkItemAssignmentProjection",
      "NotificationSourceProjection",
      "FixtureProvenance",
      "DisplaySurfaceTaxonomy",
      "ActionPolicy",
      "ExecutionReceipt",
      "SourceWritebackReceipt"
    ],
    "member_role_agent_boundary": {
      "actor_ref": "ActorRef.v1_real_human_external_or_service_account",
      "member_projection": "WorkspaceMemberProjection.v1_human_external_service_account_only",
      "project_member_projection": "ProjectMemberProjection.v1_human_external_service_account_only",
      "role_route_projection": "GovernedRoleRouteProjection.v1_invocation_routes_not_members",
      "capability_projection": "AgentCapabilityProjection.v1_automation_capabilities_not_staff",
      "runtime_event_projection": "AgentRuntimeEvent.v1_audited_execution_not_standing_membership",
      "activity_event_projection": "ActivityEventProjection.v1_typed_source_kind_not_ambiguous_who",
      "work_item_assignment_projection": "WorkItemAssignmentProjection.v1_responsible_actor_plus_supporting_routes_capabilities",
      "notification_source_projection": "NotificationSourceProjection.v1_typed_source_kind_not_member",
      "fixture_provenance": "FixtureProvenance.v1_live_fixture_legacy_planned_blocked_deferred",
      "display_surface_taxonomy": "DisplaySurfaceTaxonomy.v1_member_role_capability_runtime_event_receipt_task_activity_fixture",
      "agent_profile_status": "deferred_until_execution_persistence_assignment_audit_surface_exists"
    },
    "paid_pilot_operator_boundary": "go_with_restrictions_requires_signed_access_jwt_explicit_entitlement_action_policy_durable_receipt",
    "paid_pilot_source_writeback_boundary": "markdown_only_backend_adapter_collaboration_claim_verifier_rollback_required",
    "commercial_readiness_contracts": [
      "CommercialReadinessPosture",
      "OperatorOnboardingDecision",
      "PilotAuthorityEvidence"
    ],
    "controlled_pilot_commercial_stance": "go_with_restrictions",
    "public_self_serve_readiness": "not_claimed",
    "private_paid_operator_mode": "operator_gated_disabled_until_marat_decision_and_evidence",
    "auth_session_fixture_archetypes": [
      "marat_xlooop_xcp_admin",
      "andrey_xlooop_tenant_only",
      "named_tester_xlooop_watch_test",
      "investor_data_room_read_only",
      "authenticated_denied_no_entitlement"
    ],
    "auth_session_source_policy": "cloudflare_access_oidc_service_token_local_dev_and_test_fixture_are_authentication_sources_only_app_entry_requires_explicit_entitlement",
    "source_authority_fields": [
      "current_source_authority",
      "legacy_provenance",
      "local_clone_authority",
      "owner_boundary"
    ]
  },
  "public_safe_surface": [
    "identity_id",
    "actor_id",
    "email",
    "display_name",
    "identity_source",
    "tenant_id",
    "owner_graph_id",
