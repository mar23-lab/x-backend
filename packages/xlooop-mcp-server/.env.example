# @xlooop/mcp-server · environment variables
#
# Copy to .env (gitignored) and fill in. Both vars are optional —
# without XLOOOP_TOKEN the server falls back to ~/.xlooop/credentials.json
# (run `xlooop login` to populate).

# Bearer token used on every API request. A Clerk session JWT minted from
# an approved Xlooop user (template: xlooop-workers).
# Get one via: signed in at app.xlooop.com → DevTools Console:
#   await window.XcpClerk.instance.session.getToken({template:'xlooop-workers'})
XLOOOP_TOKEN=

# Override the Worker base URL. Default is production https://api.xlooop.com.
# Use http://localhost:8787 against `wrangler dev` from the parent repo.
# XLOOOP_API_BASE_URL=https://api.xlooop.com
