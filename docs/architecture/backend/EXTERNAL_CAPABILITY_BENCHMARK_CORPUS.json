{
  "schema_id": "xlooop.external_capability_benchmark_corpus.v1",
  "purpose": "Synthetic and redaction-safe corpus for deciding whether external capabilities can enter Xlooop backend pipelines.",
  "acceptance_gates": {
    "extraction_fidelity_pct_min": 95,
    "citation_source_span_coverage_pct_min": 95,
    "answer_equivalence_pct_min": 95,
    "token_reduction_pct_min": 25,
    "sensitive_leakage_count": 0,
    "redaction_invariant_pct": 100,
    "tenant_boundary_bypass_count": 0,
    "external_graph_authority_count": 0,
    "replayability_pct": 100,
    "p95_small_doc_conversion_ms_target": 3000
  },
  "cases": [
    {
      "id": "case-001-task-packet-basic",
      "source_type": "task_packet",
      "capability_targets": ["headroom", "hyper_extract"],
      "tenant_scope": "company_a",
      "sensitivity": "internal_task_metadata",
      "expected_outputs": {"source_span_required": true, "redaction_required": true, "tool_execution_allowed": false, "graph_authority_allowed": false}
    },
    {
