  "adoption_modes": [
    "external_benchmark",
    "canary_only",
    "restricted_adapter",
    "native_rebuild",
    "opt_in_runtime",
    "default_runtime"
  ],
  "global_pipeline": [
    "source_file",
    "sandboxed_extraction",
    "redaction",
    "acl_filter",
    "citation_and_provenance",
    "tenant_memory_projection",
    "packet_evidence_api_mcp"
  ],
  "capabilities": [
    {
      "id": "markitdown",
      "name": "microsoft/markitdown",
      "source_url": "https://github.com/microsoft/markitdown",
      "license": "MIT",
      "status": "benchmark_candidate",
      "adopted_by_default": false,
      "adoption_mode": "restricted_adapter_then_native_converter_lane",
      "runtime_surface": "backend_sandboxed_file_conversion_adapter_after_approval",
      "risk_class": "file_conversion_can_be_lossy_and_runs_with_process_io_privileges",
      "current_local_adoption": "not_adopted",
      "allowed_scopes_if_approved": [
        "tenant_scoped_file_conversion",
        "sandboxed_connector_ingestion_normalization",
        "metadata_only_conversion_fallback",
        "source_span_wrapped_markdown_generation"
      ],
      "forbidden_scopes": [
        "raw_graph",
        "full_tenant_memory",
        "secrets",
        "governance_scoring",
        "agent_routing",
        "unredacted_customer_sources",
        "network_enabled_conversion_without_allowlist",
        "plugins_enabled_without_allowlist",
        "default_customer_runtime_without_feature_flag"
      ],
      "sandbox_policy": {
        "network_default": "disabled",
        "plugin_default": "disabled",
        "file_allowlist_required": true,
        "size_limit_required": true,
        "timeout_required": true,
        "process_isolation_required": true,
        "raw_output_never_customer_authority": true
      },
      "acceptance_gates": {
        "extraction_fidelity_pct_min": 95,
        "citation_source_span_coverage_pct_min": 95,
        "sensitive_leakage_count": 0,
        "redaction_invariant_pct": 100,
        "tenant_boundary_bypass_count": 0,
        "replayability_pct": 100,
        "p95_small_doc_conversion_ms_target": 3000,
        "license_security_sbom_required": true,
        "tenant_feature_flag_required": true,
        "owner_approval_required": true
      },
      "approval_ref": null,
      "version_or_commit": null,
      "rollback_plan": "Disable tenant feature flag and replay ingestion from original object-store artifact through the previous approved converter.",
      "verifier": "npm run verify:markitdown-sandbox-adapter"
    },
